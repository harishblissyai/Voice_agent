# =============================================================
# Blissy Restaurant Voice Bot — Environment Variables
# Copy this file to .env and fill in your real keys.
# =============================================================

# Sarvam AI (STT + TTS + LLM — best for Indian languages)
# Get from: https://dashboard.sarvam.ai/
SARVAM_API_KEY=

# Groq (LLM — fast Llama inference)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic (LLM — Claude Haiku / Opus)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs (TTS + STT)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice IDs — browse at: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_TA=        # Indian-accent voice (default)
ELEVENLABS_VOICE_EN=9BWtsMINqrJLrRacOk9x   # English-accent voice
ELEVENLABS_VOICE_2=         # optional extra voice
ELEVENLABS_VOICE_3=         # optional extra voice

# Cartesia (TTS)
# Get from: https://play.cartesia.ai/keys
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=          # primary voice ID
CARTESIA_VOICE_2=           # optional
CARTESIA_VOICE_3=           # optional

# Rime AI (TTS)
# Get from: https://rime.ai/
RIME_API_KEY=

# Deepgram (STT — fallback)
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# n8n webhook — saves bookings to Google Sheets
# In n8n: Webhook node → copy URL → paste below
# Payload: name, date, time, guests, occasion, dietary
N8N_WEBHOOK_URL=

# Server config (optional — defaults shown)
HOST=0.0.0.0
PORT=8070
