# =============================================================
# Blissy Restaurant Voice Bot — Environment Variables
# Copy this file to .env and fill in your real keys.
# =============================================================

# Google AI (Gemini 2.5 Flash Lite — LLM)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Deepgram (STT — speech-to-text)
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Cartesia (TTS — Priya's Tamil voice)
# Get from: https://play.cartesia.ai/keys
CARTESIA_API_KEY=

# Cartesia Voice ID for Priya (Kavitha Tamil voice)
# Browse voices at: https://play.cartesia.ai/voice-library
CARTESIA_VOICE_ID=01d7796d-ac10-4ea3-8df0-3cc04f2d25ff

# n8n webhook URL — paste your webhook URL here
# In n8n: Webhook node → copy URL → paste below
# Payload: name, date, time, guests, occasion, dietary
N8N_WEBHOOK_URL=

# Server config (optional — defaults shown)
HOST=0.0.0.0
PORT=8000
