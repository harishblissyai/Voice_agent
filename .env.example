# =============================================================
# Blissy Restaurant Voice Bot — Environment Variables
# Copy this file to .env and fill in your real keys.
# =============================================================

# Deepgram (STT — speech-to-text, language auto-detection)
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Anthropic (LLM — Claude)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs (TTS — Priya's voice, two voices for EN/TA routing)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ElevenLabs Voice IDs
# Browse voices at: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_EN=9BWtsMINqrJLrRacOk9x
ELEVENLABS_VOICE_TA=

# n8n webhook URL — paste your webhook URL here
# In n8n: Webhook node → copy URL → paste below
# Payload: name, date, time, guests, occasion, dietary
N8N_WEBHOOK_URL=

# Server config (optional — defaults shown)
HOST=0.0.0.0
PORT=8000
