# =============================================================
# Blissy Restaurant Voice Bot — Environment Variables
# Copy this file to .env and fill in your real keys.
# =============================================================

# Anthropic (LLM — Claude Haiku)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs (TTS)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice ID — browse at: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=        # default voice for Priya

# Deepgram (STT)
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# n8n webhook — saves bookings to Google Sheets
# In n8n: Webhook node → copy URL → paste below
# Payload: name, date, time, guests, occasion, dietary
N8N_WEBHOOK_URL=

# Server config (optional — defaults shown)
HOST=0.0.0.0
PORT=8000
